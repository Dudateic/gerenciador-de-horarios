<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nova senha | Horários</title>
    <link rel="stylesheet" href="/css/login.css" />
  </head>
  <body>
    <main class="login-container">
      <section class="login-card">
        <h1>Nova senha</h1>
        <p>Crie uma nova senha com pelo menos 6 caracteres.</p>
        <% if (typeof erro !== 'undefined' && erro) { %>
        <div class="login-error"><%= erro %></div>
        <% } %>
        <form action="/nova-senha/<%= token %>" method="POST">
          <label for="senha">Nova senha</label>
          <input id="senha" name="senha" type="password" minlength="6" required />
          <label for="confirmarSenha">Confirmar senha</label>
          <input id="confirmarSenha" name="confirmarSenha" type="password" minlength="6" required />
          <button type="submit">Salvar senha</button>
        </form>
        <a class="link-muted" href="/">Voltar para o login</a>
      </section>
    </main>
  </body>
</html>
