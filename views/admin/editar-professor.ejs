<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><title>Editar Professor</title><link rel="stylesheet" href="/css/dashboard.css"><link rel="stylesheet" href="/css/form.css"></head><body><div class="container"><%- include('../partials/sidebar') %><main class="content form-page"><div class="form-card"><div class="form-header"><h2>Editar Professor</h2><a href="/admin/professores" class="close">×</a></div><%- include('../partials/messages') %><form action="/admin/professores/<%= professor.id %>/editar" method="POST"><label>Nome</label><input type="text" name="nome" value="<%= professor.nome %>" required minlength="3"><label>E-mail</label><input type="email" name="email" value="<%= professor.email || '' %>"><label>Área</label><input type="text" name="area" value="<%= professor.area || '' %>"><label>Disciplinas</label><input type="text" name="disciplinas" value="<%= professor.disciplinas || '' %>"><label>Carga semanal</label><input type="number" name="cargaSemanal" min="0" value="<%= professor.cargaSemanal || 0 %>"><label class="check"><input type="checkbox" name="ativo" <%= professor.ativo ? 'checked' : '' %>> Professor ativo</label><div class="form-actions"><a href="/admin/professores" class="btn-cancel">Cancelar</a><button type="submit">Salvar</button></div></form></div></main></div></body></html>
