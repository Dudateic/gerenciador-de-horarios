<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Editar Professor</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/form.css" />
</head>
<body>
<div class="container">
  <%- include('../partials/sidebar') %>
  <main class="content form-page">
    <section class="form-card">
      <div class="form-header">
        <h2>Editar Professor</h2>
        <a class="close" href="/admin/professores">×</a>
      </div>
      <%- include('../partials/messages') %>
      <form action="/admin/professores/<%= professor.id %>/editar" method="POST">
        <label>Nome</label>
        <input name="nome" value="<%= professor.nome %>" required minlength="3" />
        <label>E-mail</label>
        <input type="email" name="email" value="<%= professor.email || '' %>" />
        <div class="form-grid">
          <div>
            <label>Área</label>
            <input name="area" value="<%= professor.area || '' %>" placeholder="Ex.: Sistemas Digitais" />
          </div>
          <div>
            <label>Carga semanal</label>
            <input type="number" name="cargaSemanal" min="0" value="<%= professor.cargaSemanal || 0 %>" />
          </div>
        </div>
        <label>Disciplinas</label>
        <input name="disciplinas" value="<%= professor.disciplinas || '' %>" placeholder="Ex.: TEC402, TEC499" />
        <label class="check"><input type="checkbox" name="ativo" <%= professor.ativo ? 'checked' : '' %> /> Professor ativo</label>
        <div class="form-actions">
          <a class="btn-cancel" href="/admin/professores">Cancelar</a>
          <button type="submit">Salvar Alterações</button>
        </div>
      </form>
    </section>
  </main>
</div>
</body>
</html>
