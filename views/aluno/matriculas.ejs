<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Matrículas</title>
    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>
  <body>
    <div class="container">
      <%- include('../partials/aluno-sidebar') %>
      <main class="content">
        <header class="topbar">
          <div>
            <h1>Matrículas</h1>
            <p>Escolha matérias disponíveis e monte sua carga horária semanal.</p>
          </div>
          <select>
            <option>2026.2</option>
          </select>
        </header>
        <% if (erro) { %>
        <div class="alert error"><%= erro %></div>
        <% } %><% if (sucesso) { %>
        <div class="alert success"><%= sucesso %></div>
        <% } %>
        <section class="cards">
          <div class="card">
            <span>Carga atual</span>
            <strong><%= cargaAtual %>h</strong>
            <small>por semana</small>
          </div>
          <div class="card">
            <span>Limite</span>
            <strong><%= cargaMaxima %>h</strong>
            <small>máximo semanal</small>
          </div>
          <div class="card">
            <span>Selecionadas</span>
            <strong><%= matriculas.length %></strong>
            <small>turmas</small>
          </div>
          <div class="card">
            <span>Ofertas</span>
            <strong><%= turmas.length %></strong>
            <small>disponíveis</small>
          </div>
        </section>
        <section class="grid">
          <div class="panel">
            <h3>Turmas disponíveis</h3>
            <div class="table-wrapper">
              <table class="table">
                <thead>
                  <tr>
                    <th>Disciplina</th>
                    <th>Professor</th>
                    <th>Dias</th>
                    <th>Horário</th>
                    <th>Sala</th>
                    <th>Vagas</th>
                    <th>Validação</th>
                    <th>Ação</th>
                  </tr>
                </thead>
                <tbody>
  <% if (!turmas || turmas.length === 0) { %>
    <tr>
      <td colspan="8">Nenhuma turma disponível.</td>
    </tr>
  <% } else { %>
    <% turmas.forEach(turma => { %>
      <tr>
        <td>
          <span class="color-dot"></span>
          <strong><%= turma.disciplina || turma.nome %></strong>
          <br />
          <small>
            Carga: <%= turma.cargaTurma %>h | Pré: <%= turma.prerequisitoTexto %>
          </small>
        </td>

        <td><%= turma.professor || "-" %></td>
        <td><%= turma.dias || "-" %></td>
        <td><%= turma.horario || "-" %></td>
        <td><%= turma.sala || "-" %></td>
        <td><%= turma.vagasOcupadas || 0 %>/<%= turma.vagas || 0 %></td>

        <td>
          <% if (turma.podeAdicionar) { %>
            <span class="badge active">Liberada</span>
          <% } else { %>
            <span class="badge inactive"><%= turma.bloqueio %></span>
          <% } %>
        </td>

        <td>
          <% if (turma.podeAdicionar) { %>
            <form action="/aluno/matriculas/adicionar" method="POST">
              <input type="hidden" name="turmaId" value="<%= turma.id %>" />
              <button class="btn-edit" type="submit">Adicionar</button>
            </form>
          <% } else { %>
            <button class="btn-delete" type="button" disabled>Bloqueada</button>
          <% } %>
        </td>
      </tr>
    <% }) %>
  <% } %>
</tbody>
              </table>
            </div>
          </div>
          <div class="panel">
            <h3>Minha grade</h3>
            <div class="table-wrapper">
              <table class="table">
                <thead>
                  <tr>
                    <th>Disciplina</th>
                    <th>Horário</th>
                    <th>Ação</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!matriculas || matriculas.length === 0) { %>
                  <tr><td colspan="3">Sua grade ainda está vazia.</td></tr>
                  <% } else { %><% matriculas.forEach(item => { const turma = item.turma; %>
                  <tr>
                    <td><%= turma.disciplina || turma.nome %></td>
                    <td><%= turma.dias || "-" %> • <%= turma.horario || "-" %></td>
                    <td>
                      <form
                        action="/aluno/matriculas/<%= item.matricula.id %>/remover"
                        method="POST"
                      >
                        <button class="btn-delete" type="submit">Remover</button>
                      </form>
                    </td>
                  </tr>
                  <% }) %><% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
